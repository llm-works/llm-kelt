# Local environment configuration
# Copy this file to .env.yaml and customize for your setup
#
#   cp .env.yaml.example .env.yaml
#
# .env.yaml is gitignored and will not be committed.

# Paths to local model storage
paths:
  # Directory containing HuggingFace models for training/inference
  models: !path ~/models/huggingface

  # Directory for trained LoRA adapters (used by llm-infer)
  adapters: !path ~/models/adapters/LoRA
